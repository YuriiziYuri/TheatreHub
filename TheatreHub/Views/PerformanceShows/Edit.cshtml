@model TheatreHub.Models.PerformanceShow

@{
    ViewData["Title"] = "Редагувати показ";
}

<div class="container my-4">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">

            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="h3 mb-1">
                        Редагувати показ
                    </h1>

                    <p class="text-muted mb-0">
                        Оновлення даних про показ вистави.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Details"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">
                        До деталей
                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-dark">
                        До списку
                    </a>
                </div>
            </div>

            <form asp-action="Edit"
                  asp-route-id="@Model.Id"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       asp-for="Id" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="PerformanceId"
                           class="form-label">
                        Вистава
                    </label>

                    <select asp-for="PerformanceId"
                            asp-items="ViewBag.PerformanceOptions"
                            class="form-select"></select>

                    <span asp-validation-for="PerformanceId"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HallId"
                           class="form-label">
                        Зал
                    </label>

                    <select asp-for="HallId"
                            asp-items="ViewBag.HallOptions"
                            class="form-select"></select>

                    <span asp-validation-for="HallId"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ExternalLocation"
                           class="form-label">
                        Зовнішня локація
                    </label>

                    <input asp-for="ExternalLocation"
                           class="form-control"
                           placeholder="Наприклад: школа, будинок культури, виїзна сцена" />

                    <span asp-validation-for="ExternalLocation"
                          class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="StartDateTime"
                               class="form-label">
                            Початок
                        </label>

                        <input asp-for="StartDateTime"
                               type="datetime-local"
                               class="form-control" />

                        <span asp-validation-for="StartDateTime"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EndDateTime"
                               class="form-label">
                            Завершення
                        </label>

                        <input asp-for="EndDateTime"
                               type="datetime-local"
                               class="form-control" />

                        <span asp-validation-for="EndDateTime"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label asp-for="Type"
                               class="form-label">
                            Тип показу
                        </label>

                        <select asp-for="Type"
                                asp-items="ViewBag.TypeOptions"
                                class="form-select"></select>

                        <span asp-validation-for="Type"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Status"
                               class="form-label">
                            Статус
                        </label>

                        <select asp-for="Status"
                                asp-items="ViewBag.StatusOptions"
                                class="form-select"></select>

                        <span asp-validation-for="Status"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label asp-for="ExpectedAudienceCount"
                               class="form-label">
                            Очікувана кількість глядачів
                        </label>

                        <input asp-for="ExpectedAudienceCount"
                               type="number"
                               min="0"
                               class="form-control" />

                        <span asp-validation-for="ExpectedAudienceCount"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ActualAudienceCount"
                               class="form-label">
                            Фактична кількість глядачів
                        </label>

                        <input asp-for="ActualAudienceCount"
                               type="number"
                               min="0"
                               class="form-control" />

                        <span asp-validation-for="ActualAudienceCount"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Notes"
                           class="form-label">
                        Примітки
                    </label>

                    <textarea asp-for="Notes"
                              class="form-control"
                              rows="4"
                              placeholder="Додаткова інформація про показ"></textarea>

                    <span asp-validation-for="Notes"
                          class="text-danger"></span>
                </div>

                <div class="d-flex flex-wrap justify-content-end gap-2 mt-4">
                    <a asp-action="Details"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">
                        Скасувати
                    </a>

                    <button type="submit"
                            class="btn btn-primary">
                        Зберегти зміни
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
