@model TheatreHub.ViewModels.DashboardViewModel

@using Microsoft.AspNetCore.Authorization
@using TheatreHub.Constants

@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Панель керування";

    var canManagePerformances =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManagePerformances)).Succeeded;

    var canManageRehearsals =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManageRehearsals)).Succeeded;

    var canViewFinance =
        User.IsInRole(UserRoles.SystemAdmin) ||
        User.IsInRole(UserRoles.GeneralDirector) ||
        User.IsInRole(UserRoles.FinanceManager);

    var canViewAdmin =
        User.IsInRole(UserRoles.SystemAdmin) ||
        User.IsInRole(UserRoles.GeneralDirector);
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">
            Панель керування TheatreHub
        </h1>

        <p class="text-muted mb-0">
            Загальне зведення по виставах, репетиціях, завданнях, фінансах і підготовці.
        </p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Calendar"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Календар
        </a>

        @if (canManagePerformances)
        {
            <a asp-controller="Performances"
               asp-action="Create"
               class="btn btn-primary">
                Створити виставу
            </a>
        }

        @if (canManageRehearsals)
        {
            <a asp-controller="Rehearsals"
               asp-action="Create"
               class="btn btn-outline-primary">
                Створити репетицію
            </a>
        }
    </div>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">
                    Вистави
                </div>

                <div class="fs-3 fw-semibold">
                    @Model.PerformancesCount
                </div>

                <div class="small text-muted">
                    У підготовці: @Model.PerformancesInPreparationCount
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">
                    Актори
                </div>

                <div class="fs-3 fw-semibold">
                    @Model.ActiveActorsCount
                </div>

                <div class="small text-muted">
                    Доступні для призначень
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">
                    Найближчі репетиції
                </div>

                <div class="fs-3 fw-semibold">
                    @Model.UpcomingRehearsalsCount
                </div>

                <div class="small text-muted">
                    Заплановані від сьогодні
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">
                    Відкриті завдання
                </div>

                <div class="fs-3 fw-semibold">
                    @Model.OpenTasksCount
                </div>

                <div class="small text-muted">
                    Прострочено: @Model.OverdueTasksCount · Критичні: @Model.CriticalTasksCount
                </div>
            </div>
        </div>
    </div>

</div>

@if (canViewFinance)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div>
                    <h2 class="h4 mb-1">
                        Фінансовий підсумок
                    </h2>

                    <p class="text-muted mb-0">
                        Загальна картина доходів і витрат по системі.
                    </p>
                </div>

                <a asp-controller="BudgetTransactions"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary">
                    Відкрити фінанси
                </a>
            </div>

            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">
                            Планові доходи
                        </div>

                        <div class="fs-5 fw-semibold">
                            @Model.PlannedIncomeTotal.ToString("N2") грн
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">
                            Планові витрати
                        </div>

                        <div class="fs-5 fw-semibold">
                            @Model.PlannedExpenseTotal.ToString("N2") грн
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">
                            Плановий баланс
                        </div>

                        <div class="fs-5 fw-semibold">
                            @Model.PlannedProfit.ToString("N2") грн
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">
                            Фактичний баланс
                        </div>

                        <div class="fs-5 fw-semibold">
                            @Model.ActualProfit.ToString("N2") грн
                        </div>

                        <div class="small text-muted">
                            Доходи: @Model.ActualIncomeTotal.ToString("N2") · Витрати: @Model.ActualExpenseTotal.ToString("N2")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4 mb-4">

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h4 mb-0">
                        Найближчі репетиції
                    </h2>

                    <a asp-controller="Calendar"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-secondary">
                        Календар
                    </a>
                </div>

                @if (!Model.UpcomingRehearsals.Any())
                {
                    <div class="alert alert-info mb-0">
                        Найближчих репетицій немає.
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var rehearsal in Model.UpcomingRehearsals)
                        {
                            <a asp-controller="Rehearsals"
                               asp-action="Details"
                               asp-route-id="@rehearsal.Id"
                               class="list-group-item list-group-item-action">

                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                    <strong>
                                        @rehearsal.StartDateTime.ToString("dd.MM.yyyy HH:mm")
                                        —
                                        @rehearsal.EndDateTime.ToString("HH:mm")
                                    </strong>

                                    <span class="badge text-bg-secondary">
                                        @rehearsal.StatusText
                                    </span>
                                </div>

                                <div class="small text-muted">
                                    @rehearsal.PerformanceTitle
                                </div>

                                <div class="small text-muted">
                                    @rehearsal.TargetText
                                </div>

                                <div class="small text-muted">
                                    @rehearsal.HallText
                                </div>
                            </a>
                        }
                    </div>
                }

            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">

                <h2 class="h4 mb-3">
                    Швидкі переходи
                </h2>

                <div class="d-grid gap-2">
                    <a asp-controller="Performances"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Вистави
                    </a>

                    <a asp-controller="TheatreTasks"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Завдання
                    </a>

                    <a asp-controller="ProductionItems"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Реквізит / костюми / грим
                    </a>

                    @if (canViewFinance)
                    {
                        <a asp-controller="BudgetTransactions"
                           asp-action="Index"
                           class="btn btn-outline-primary">
                            Фінанси
                        </a>
                    }

                    @if (canViewAdmin)
                    {
                        <a asp-controller="AdminActionLogs"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Журнал дій
                        </a>

                        <a asp-controller="AdminBackups"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Резервні копії
                        </a>
                    }
                </div>

            </div>
        </div>
    </div>

</div>

<div class="row g-4 mb-4">

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h4 mb-0">
                        Завдання, які потребують уваги
                    </h2>

                    <a asp-controller="TheatreTasks"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-secondary">
                        Усі завдання
                    </a>
                </div>

                @if (!Model.AttentionTasks.Any())
                {
                    <div class="alert alert-success mb-0">
                        Немає прострочених або критичних відкритих завдань.
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var task in Model.AttentionTasks)
                        {
                            <a asp-controller="TheatreTasks"
                               asp-action="Details"
                               asp-route-id="@task.Id"
                               class="list-group-item list-group-item-action">

                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                    <strong>
                                        @task.Title
                                    </strong>

                                    <span>
                                        @if (task.IsOverdue)
                                        {
                                            <span class="badge text-bg-danger">
                                                Прострочено
                                            </span>
                                        }

                                    <span class="badge text-bg-secondary">
                                        @task.PriorityText
                                    </span>
                                </span>
                            </div>

                            <div class="small text-muted">
                                @task.PerformanceTitle
                            </div>

                            <div class="small text-muted">
                                @task.TargetText
                            </div>

                            <div class="small text-muted">
                                Дедлайн:
                                @(task.Deadline.HasValue
                                                            ? task.Deadline.Value.ToString("dd.MM.yyyy HH:mm")
                                                            : "не вказано")
                        </div>
                    </a>
                                        }
                    </div>
                }

            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h4 mb-0">
                        Реквізит / костюми / грим
                    </h2>

                    <a asp-controller="ProductionItems"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-secondary">
                        Усі елементи
                    </a>
                </div>

                @if (!Model.ProblemProductionItems.Any())
                {
                    <div class="alert alert-success mb-0">
                        Немає проблемних або прострочених постановочних елементів.
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var item in Model.ProblemProductionItems)
                        {
                            <a asp-controller="ProductionItems"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="list-group-item list-group-item-action">

                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                    <strong>
                                        @item.Name
                                    </strong>

                                    <span>
                                        @if (item.IsOverdue)
                                        {
                                            <span class="badge text-bg-danger">
                                                Прострочено
                                            </span>
                                        }

                                    <span class="badge text-bg-secondary">
                                        @item.TypeText
                                    </span>
                                </span>
                            </div>

                            <div class="small text-muted">
                                @item.PerformanceTitle
                            </div>

                            <div class="small text-muted">
                                Статус: @item.StatusText
                            </div>

                            <div class="small text-muted">
                                Потрібно до:
                                @(item.NeededBy.HasValue
                                                            ? item.NeededBy.Value.ToString("dd.MM.yyyy HH:mm")
                                                            : "не вказано")
                        </div>
                    </a>
                                        }
                    </div>
                }

            </div>
        </div>
    </div>

</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">

        <h2 class="h4 mb-3">
            Вистави, які потребують уваги
        </h2>

        @if (!Model.AttentionPerformances.Any())
        {
            <div class="alert alert-success mb-0">
                Немає вистав із помітними проблемами підготовки.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var performance in Model.AttentionPerformances)
                {
                    <div class="list-group-item">

                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">

                            <div>
                                <h3 class="h5 mb-1">
                                    @performance.Title
                                </h3>

                                <div class="small text-muted">
                                    Статус: @performance.StatusText
                                </div>

                                <div class="small text-muted">
                                    Прем’єра:
                                    @(performance.PremiereDate.HasValue
                                                                ? performance.PremiereDate.Value.ToString("dd.MM.yyyy")
                                                                : "не вказано")
                                                                           </div>

                                <div class="small text-muted">
                                    Наступна репетиція:
                                    @(string.IsNullOrWhiteSpace(performance.NextRehearsalText)
                                                                ? "не заплановано"
                                                                : performance.NextRehearsalText)
                        </div>

                                <div class="small mt-2">
                                    Ролі без основного актора:
                                    <strong>@performance.RolesWithoutMainCast</strong>
                                    · Відкриті завдання:
                                    <strong>@performance.OpenTasksCount</strong>
                                    · Проблемний реквізит:
                                    <strong>@performance.ProblemProductionItemsCount</strong>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                        @if (canManagePerformances)
                                {
                                    <a asp-controller="Performances"
                                       asp-action="Preparation"
                                       asp-route-id="@performance.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        Контроль
                                    </a>
                                }

                                <a asp-controller="Performances"
                                   asp-action="Details"
                                   asp-route-id="@performance.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Вистава
                                </a>
                            </div>

                        </div>

                    </div>
                }
            </div>
        }

    </div>
</div>

@if (canViewAdmin)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <h2 class="h4 mb-0">
                    Останні дії користувачів
                </h2>

                <a asp-controller="AdminActionLogs"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary">
                    Весь журнал
                </a>
            </div>

            @if (!Model.RecentActionLogs.Any())
            {
                <div class="alert alert-info mb-0">
                    Поки що немає записів у журналі дій.
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var log in Model.RecentActionLogs)
                    {
                        <div class="list-group-item">
                            <div class="d-flex flex-wrap justify-content-between gap-2">
                                <strong>
                                    @log.UserFullName
                                </strong>

                                <span class="small text-muted">
                                    @log.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </span>
                            </div>

                            <div class="small text-muted">
                                @log.ActionType · @log.EntityType
                                @if (!string.IsNullOrWhiteSpace(log.EntityTitle))
                                {
                                    <span> · @log.EntityTitle</span>
                                }
                            </div>

                            <div>
                                @log.Description
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="text-center mt-4 mb-2">
                <a asp-controller="Home"
                   asp-action="Privacy"
                   class="text-muted small text-decoration-none">
                    Політика користування
                </a>
            </div>

        </div>
    </div>
}