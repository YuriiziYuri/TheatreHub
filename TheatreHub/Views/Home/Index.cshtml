@using TheatreHub.Models.Enums
@model TheatreHub.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Головна";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold mb-1">
        TheatreHub
    </h1>

    <p class="text-muted mb-0">
        Інформаційна система керування театром
    </p>
</div>

<div class="row g-3 mb-4">

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">
                    Вистави
                </div>

                <div class="display-6 fw-semibold">
                    @Model.PerformancesCount
                </div>

                <a asp-controller="Performances"
                   asp-action="Index"
                   class="small text-decoration-none">
                    Переглянути вистави
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">
                    Актори
                </div>

                <div class="display-6 fw-semibold">
                    @Model.ActorsCount
                </div>

                <a asp-controller="Actors"
                   asp-action="Index"
                   class="small text-decoration-none">
                    Переглянути акторів
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">
                    Вакантні ролі
                </div>

                <div class="display-6 fw-semibold">
                    @Model.VacantRolesCount
                </div>

                <a asp-controller="CharacterRoles"
                   asp-action="Index"
                   class="small text-decoration-none">
                    Розподілити ролі
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">
                    Майбутні репетиції
                </div>

                <div class="display-6 fw-semibold">
                    @Model.UpcomingRehearsalsCount
                </div>

                <a asp-controller="Rehearsals"
                   asp-action="Index"
                   class="small text-decoration-none">
                    Переглянути розклад
                </a>
            </div>
        </div>
    </div>

</div>

<div class="row g-4">

    <div class="col-lg-8">

        <div class="card border-0 shadow-sm mb-4">

            <div class="card-header bg-white border-0 pt-4 px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="h5 mb-1">
                            Найближчі репетиції
                        </h2>

                        <p class="text-muted small mb-0">
                            П’ять найближчих запланованих репетицій
                        </p>
                    </div>

                    <a asp-controller="Rehearsals"
                       asp-action="Create"
                       class="btn btn-sm btn-primary">
                        Додати
                    </a>
                </div>
            </div>

            <div class="card-body px-4 pb-4">

                @if (!Model.UpcomingRehearsals.Any())
                {
                    <div class="alert alert-info mb-0">
                        Майбутніх репетицій поки немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Вистава</th>
                                    <th>Дата і час</th>
                                    <th>Місце</th>
                                    <th>Учасники</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var rehearsal
                                    in Model.UpcomingRehearsals)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @rehearsal.Performance.Title
                                        </td>

                                        <td>
                                            @(rehearsal.StartDateTime.ToString("dd.MM.yyyy HH:mm"))
                                        </td>

                                        <td>
                                            <div>@rehearsal.Hall.Name</div>
                                            <div class="small text-muted">
                                                @rehearsal.Hall.Venue.Name
                                            </div>
                                        </td>

                                        <td>
                                            @rehearsal.Participants.Count
                                        </td>

                                        <td class="text-end">
                                            <a asp-controller="Rehearsals"
                                               asp-action="Details"
                                               asp-route-id="@rehearsal.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                Відкрити
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </div>

        <div class="card border-0 shadow-sm">

            <div class="card-header bg-white border-0 pt-4 px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="h5 mb-1">
                            Активні вистави
                        </h2>

                        <p class="text-muted small mb-0">
                            Вистави, робота над якими ще триває
                        </p>
                    </div>

                    <a asp-controller="Performances"
                       asp-action="Create"
                       class="btn btn-sm btn-primary">
                        Додати
                    </a>
                </div>
            </div>

            <div class="card-body px-4 pb-4">

                @if (!Model.ActivePerformances.Any())
                {
                    <div class="alert alert-info mb-0">
                        Активних вистав поки немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Назва</th>
                                    <th>Жанр</th>
                                    <th>Статус</th>
                                    <th>Ролі</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var performance
                                    in Model.ActivePerformances)
                                {
                                    var assignedRoles =
                                    performance.CharacterRoles.Count(role =>
                                    role.Assignments.Any(assignment =>
                                    assignment.IsCurrent &&
                                    assignment.CastType == CastType.Main &&
                                    assignment.Status == RoleAssignmentStatus.Approved));

                                    var totalRoles =
                                        performance.CharacterRoles.Count;

                                    <tr>
                                        <td class="fw-semibold">
                                            @performance.Title
                                        </td>

                                        <td>
                                            @performance.Genre
                                        </td>

                                        <td>
                                            @Html.DisplayFor(
                                                modelItem =>
                                                    performance.Status)
                                        </td>

                                        <td>
                                            @assignedRoles / @totalRoles
                                        </td>

                                        <td class="text-end">
                                            <a asp-controller="Performances"
                                               asp-action="Details"
                                               asp-route-id="@performance.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                Відкрити
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </div>

    </div>

    <div class="col-lg-4">

        <div class="card border-0 shadow-sm">

            <div class="card-header bg-white border-0 pt-4 px-4">
                <h2 class="h5 mb-1">
                    Вакантні ролі
                </h2>

                <p class="text-muted small mb-0">
                    Персонажі без призначеного актора
                </p>
            </div>

            <div class="card-body px-4 pb-4">

                @if (!Model.VacantRoles.Any())
                {
                    <div class="alert alert-success mb-0">
                        Усі ролі розподілені.
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">

                        @foreach (var role in Model.VacantRoles)
                        {
                            <a asp-controller="CharacterRoles"
                               asp-action="Edit"
                               asp-route-id="@role.Id"
                               class="list-group-item
                                      list-group-item-action
                                      px-0">

                                <div class="fw-semibold">
                                    @role.Name
                                </div>

                                <div class="small text-muted">
                                    @role.Performance.Title
                                </div>
                            </a>
                        }

                    </div>

                    <div class="mt-3">
                        <a asp-controller="CharacterRoles"
                           asp-action="Index"
                           class="btn btn-outline-secondary w-100">
                            Усі персонажі
                        </a>
                    </div>
                }

            </div>
        </div>

    </div>

</div>