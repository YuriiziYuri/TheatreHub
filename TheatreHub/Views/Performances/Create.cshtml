@model TheatreHub.Models.Performance
@using TheatreHub.Models.Enums

@{
    ViewData["Title"] = "Додавання вистави";
}

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 mb-1">
                    Додавання вистави
                </h1>

                <p class="text-muted mb-4">
                    Спочатку введіть основні дані.
                    Після збереження можна перейти до створення
                    дій та сцен.
                </p>

                <form asp-action="Create"
                      method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title"
                               class="form-label fw-semibold">
                        </label>

                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Назва вистави" />

                        <span asp-validation-for="Title"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description"
                               class="form-label fw-semibold">
                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Короткий опис вистави"></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Genre"
                               class="form-label fw-semibold">
                        </label>

                        <input asp-for="Genre"
                               class="form-control"
                               placeholder="Наприклад: драма, комедія, казка" />

                        <span asp-validation-for="Genre"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PremiereDate"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="PremiereDate"
                                   class="form-control"
                                   type="date" />

                            <span asp-validation-for="PremiereDate"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="DurationMinutes"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="DurationMinutes"
                                   class="form-control"
                                   type="number"
                                   min="1"
                                   max="600" />

                            <span asp-validation-for="DurationMinutes"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PlannedBudget"
                               class="form-label fw-semibold">
                            Плановий бюджет
                        </label>

                        <input asp-for="PlannedBudget"
                               class="form-control"
                               type="number"
                               step="0.01"
                               min="0"
                               placeholder="Наприклад: 50000" />

                        <span asp-validation-for="PlannedBudget"
                              class="text-danger">
                        </span>

                        <div class="form-text">
                            Орієнтовна сума, яку планується витратити на підготовку вистави.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="Status"
                                asp-items="Html.GetEnumSelectList<PerformanceStatus>()"
                                class="form-select">
                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="d-flex flex-wrap gap-2">

                        <button type="submit"
                                name="submitAction"
                                value="save"
                                class="btn btn-primary px-4">
                            Зберегти
                        </button>

                        <button type="submit"
                                name="submitAction"
                                value="structure"
                                class="btn btn-outline-primary">
                            Зберегти й перейти до структури
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            Скасувати
                        </a>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial");
    }
}