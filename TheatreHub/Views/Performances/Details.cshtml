@model TheatreHub.Models.Performance
@using TheatreHub.Models.Enums

@{
    ViewData["Title"] = "Інформація про виставу";

    var statusClass = Model.Status switch
    {
        PerformanceStatus.Idea => "bg-secondary",
        PerformanceStatus.Planning => "bg-info text-dark",
        PerformanceStatus.Casting => "bg-warning text-dark",
        PerformanceStatus.RehearsalPeriod => "bg-primary",
        PerformanceStatus.ReadyForPremiere => "bg-success",
        PerformanceStatus.InRepertoire => "bg-success",
        PerformanceStatus.Completed => "bg-dark",
        PerformanceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h1 class="h3 mb-1">@Model.Title</h1>
                        <p class="text-muted mb-0">
                            Інформація про театральну постановку
                        </p>
                    </div>

                    <span class="badge @statusClass">
                        @Html.DisplayFor(model => model.Status)
                    </span>
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4">Опис</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Description)
                            ? "Опис відсутній"
                            : Model.Description)
                    </dd>

                    <dt class="col-sm-4">Жанр</dt>
                    <dd class="col-sm-8">@Model.Genre</dd>

                    <dt class="col-sm-4">Дата прем’єри</dt>
                    <dd class="col-sm-8">
                        @(Model.PremiereDate?.ToString("dd.MM.yyyy")
                            ?? "Не вказано")
                    </dd>

                    <dt class="col-sm-4">Тривалість</dt>
                    <dd class="col-sm-8">
                        @Model.DurationMinutes хв
                    </dd>

                    <dt class="col-sm-4">Дата створення запису</dt>
                    <dd class="col-sm-8">
                        @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </dd>
                </dl>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary">
                        Редагувати
                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        До списку
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>