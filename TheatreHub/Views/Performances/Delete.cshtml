@model TheatreHub.Models.Performance

@{
    ViewData["Title"] = "Видалення вистави";

    var performanceShowsCount =
        ViewBag.PerformanceShowsCount as int? ?? 0;

    var budgetTransactionsCount =
        ViewBag.BudgetTransactionsCount as int? ?? 0;

    var tasksCount =
        ViewBag.TasksCount as int? ?? 0;

    var productionItemsCount =
        ViewBag.ProductionItemsCount as int? ?? 0;

    var actsCount =
        Model.Acts?.Count ?? 0;

    var rolesCount =
        Model.CharacterRoles?.Count ?? 0;

    var rehearsalsCount =
        Model.Rehearsals?.Count ?? 0;

    var cannotDelete =
        actsCount > 0 ||
        rolesCount > 0 ||
        rehearsalsCount > 0 ||
        performanceShowsCount > 0 ||
        budgetTransactionsCount > 0 ||
        tasksCount > 0 ||
        productionItemsCount > 0;
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-danger shadow-sm">
            <div class="card-body p-4">

                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                    <div>
                        <h1 class="h3 text-danger mb-2">
                            Видалення вистави
                        </h1>

                        <p class="text-muted mb-0">
                            Цю дію неможливо скасувати.
                        </p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-primary">
                            До вистави
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            До списку
                        </a>
                    </div>
                </div>

                <div class="alert alert-warning">
                    Ви дійсно хочете видалити виставу
                    <strong>@Model.Title</strong>?
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Жанр</dt>
                    <dd class="col-sm-8">@Model.Genre</dd>

                    <dt class="col-sm-4">Дата прем’єри</dt>
                    <dd class="col-sm-8">
                        @(Model.PremiereDate?.ToString("dd.MM.yyyy") ?? "Не вказано")
                    </dd>

                    <dt class="col-sm-4">Тривалість</dt>
                    <dd class="col-sm-8">
                        @Model.DurationMinutes хв
                    </dd>

                    <dt class="col-sm-4">Дії</dt>
                    <dd class="col-sm-8">@actsCount</dd>

                    <dt class="col-sm-4">Ролі</dt>
                    <dd class="col-sm-8">@rolesCount</dd>

                    <dt class="col-sm-4">Репетиції</dt>
                    <dd class="col-sm-8">@rehearsalsCount</dd>

                    <dt class="col-sm-4">Покази</dt>
                    <dd class="col-sm-8">@performanceShowsCount</dd>

                    <dt class="col-sm-4">Завдання</dt>
                    <dd class="col-sm-8">@tasksCount</dd>

                    <dt class="col-sm-4">Постановочні елементи</dt>
                    <dd class="col-sm-8">@productionItemsCount</dd>

                    <dt class="col-sm-4">Фінансові операції</dt>
                    <dd class="col-sm-8">@budgetTransactionsCount</dd>
                </dl>

                @if (budgetTransactionsCount > 0)
                {
                    <div class="alert alert-warning">
                        <strong>Увага!</strong>
                        До цієї вистави прив’язано фінансових операцій:
                        <strong>@budgetTransactionsCount</strong>.

                        <br />

                        Видалити виставу не можна, поки існують фінансові операції.
                        Спочатку видаліть або перенесіть фінансові операції.
                    </div>
                }

                @if (performanceShowsCount > 0)
                {
                    <div class="alert alert-warning">
                        <strong>Увага!</strong>
                        До цієї вистави прив’язано показів:
                        <strong>@performanceShowsCount</strong>.

                        <br />

                        Видалити виставу не можна, поки існують покази.
                    </div>
                }

                @if (cannotDelete)
                {
                    <div class="alert alert-danger">
                        Виставу не можна видалити, бо вона має пов’язані дані:
                        структуру, ролі, репетиції, покази, завдання,
                        постановочні елементи або фінансові операції.
                        Спочатку видаліть або перенесіть пов’язані дані.
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="button"
                                class="btn btn-danger"
                                disabled>
                            Видалити
                        </button>

                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-primary">
                            До вистави
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            До списку
                        </a>
                    </div>
                }
                else
                {
                    <form asp-action="Delete"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               asp-for="Id" />

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit"
                                    class="btn btn-danger">
                                Видалити
                            </button>

                            <a asp-action="Details"
                               asp-route-id="@Model.Id"
                               class="btn btn-outline-primary">
                                Скасувати
                            </a>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">
                                До списку
                            </a>
                        </div>

                    </form>
                }

            </div>
        </div>

    </div>
</div>
