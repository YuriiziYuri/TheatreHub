@model TheatreHub.Models.Actor

@{
    ViewData["Title"] = "Додавання актора";
}

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 mb-1">Додавання актора</h1>

                <p class="text-muted mb-4">
                    Введіть особисті та контактні дані актора.
                </p>

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="FirstName"
                                   class="form-control"
                                   placeholder="Ім’я" />

                            <span asp-validation-for="FirstName"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="LastName"
                                   class="form-control"
                                   placeholder="Прізвище" />

                            <span asp-validation-for="LastName"
                                  class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Email"
                               class="form-control"
                               type="email"
                               placeholder="example@email.com" />

                        <span asp-validation-for="Email"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber"
                               class="form-label fw-semibold"></label>

                        <input asp-for="PhoneNumber"
                               class="form-control"
                               placeholder="+380..." />

                        <span asp-validation-for="PhoneNumber"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes"
                               class="form-label fw-semibold"></label>

                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Додаткова інформація про актора"></textarea>

                        <span asp-validation-for="Notes"
                              class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary px-4">
                            Додати
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            Скасувати
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}