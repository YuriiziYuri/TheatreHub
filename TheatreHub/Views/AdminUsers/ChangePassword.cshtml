<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] — TheatreHub</title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/TheatreHub.styles.css"
          asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    TheatreHub
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Відкрити меню">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse"
                     id="mainNavbar">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Головна
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Вистави
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Performances"
                                       asp-action="Index">
                                        Вистави
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="PerformanceShows"
                                       asp-action="Index">
                                        Покази
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Actors"
                                       asp-action="Index">
                                        Актори
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="CharacterRoles"
                                       asp-action="Index">
                                        Персонажі
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="RoleAssignments"
                                       asp-action="Index">
                                        Акторські склади
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Rehearsals"
                               asp-action="Index">
                                Репетиції
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Постановка
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="TheatreTasks"
                                       asp-action="Index">
                                        Завдання
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="ProductionItems"
                                       asp-action="Index">
                                        Реквізит / костюми / грим
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Venues"
                                       asp-action="Index">
                                        Майданчики
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Halls"
                                       asp-action="Index">
                                        Зали
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Calendar"
                               asp-action="Index">
                                Календар
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="BudgetTransactions"
                               asp-action="Index">
                                Фінанси
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Адміністрування
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminUsers"
                                       asp-action="Index">
                                        Користувачі
                                    </a>
                                </li>
                            </ul>
                        </li>

                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="container-fluid flex-grow-1 py-4 px-4">
        @RenderBody()
    </main>

    <footer class="border-top bg-light text-muted py-3 mt-auto">
        <div class="container text-center">
            &copy; 2026 TheatreHub —
            інформаційна система керування театром
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
