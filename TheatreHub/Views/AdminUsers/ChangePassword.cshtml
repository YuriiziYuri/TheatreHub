@model TheatreHub.ViewModels.AdminUsers.AdminUserChangePasswordViewModel

@{
    ViewData["Title"] = "Змінити пароль";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Змінити пароль</h1>
        <p class="text-muted mb-0">
            Встановлення нового пароля для облікового запису.
        </p>
    </div>

    <a asp-controller="AdminUsers"
       asp-action="Index"
       class="btn btn-outline-secondary">
        ← Назад до списку
    </a>
</div>

<div class="card">
    <div class="card-header">
        Дані користувача
    </div>

    <div class="card-body">
        <div class="mb-4">
            <div>
                <strong>Користувач:</strong>
                @Model.FullName
            </div>

            <div>
                <strong>Email:</strong>
                @Model.Email
            </div>
        </div>

        <form asp-controller="AdminUsers"
              asp-action="ChangePassword"
              asp-route-id="@Model.UserId"
              method="post">

            @Html.AntiForgeryToken()

            <input asp-for="UserId" type="hidden" />
            <input asp-for="FullName" type="hidden" />
            <input asp-for="Email" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword"
                       class="form-label">
                    Новий пароль
                </label>

                <input asp-for="NewPassword"
                       type="password"
                       class="form-control"
                       autocomplete="new-password"
                       placeholder="Введіть новий пароль" />

                <span asp-validation-for="NewPassword"
                      class="text-danger">
                </span>

                <div class="form-text">
                    Пароль має містити щонайменше 6 символів.
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary">
                    Змінити пароль
                </button>

                <a asp-controller="AdminUsers"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Скасувати
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}