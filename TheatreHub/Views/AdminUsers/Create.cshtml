@model TheatreHub.ViewModels.AdminUsers.AdminUserCreateViewModel

@{
    ViewData["Title"] = "Додати користувача";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Додати користувача</h1>
        <p class="text-muted mb-0">
            Створення нового облікового запису для працівника театру.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Назад до списку
    </a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="card mb-3">
        <div class="card-header">
            Основна інформація
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label">
                        Повне ім’я
                    </label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">
                        Email
                    </label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label">
                        Пароль
                    </label>
                    <input asp-for="Password"
                           type="password"
                           class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="JobTitle" class="form-label">
                        Посада / спеціалізація
                    </label>
                    <input asp-for="JobTitle"
                           class="form-control"
                           placeholder="Наприклад: режисер, актор, костюмер" />
                    <span asp-validation-for="JobTitle" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ActorId" class="form-label">
                        Прив’язаний актор
                    </label>

                    <select asp-for="ActorId" class="form-select">
                        <option value="">Не прив’язувати</option>

                        @foreach (var actor in Model.Actors)
                        {
                            <option value="@actor.Id">
                                @actor.FullName
                            </option>
                        }
                    </select>

                    <span asp-validation-for="ActorId" class="text-danger"></span>
                    <div class="form-text">
                        Використовується, якщо цей користувач є актором у системі.
                    </div>
                </div>

                <div class="col-md-6 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">
                            Активний користувач
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            Ролі користувача
        </div>

        <div class="card-body">
            @if (!Model.AvailableRoles.Any())
            {
                <div class="alert alert-warning mb-0">
                    Ролі ще не створені в системі.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        var checkboxId = $"role_{role}";

                        <div class="col-md-4 mb-2">
                            <div class="form-check">
                                <input type="checkbox"
                                       id="@checkboxId"
                                       name="SelectedRoles"
                                       value="@role"
                                       class="form-check-input"
                                       checked="@Model.SelectedRoles.Contains(role)" />

                                <label for="@checkboxId" class="form-check-label">
                                    @role
                                </label>
                            </div>
                        </div>
                    }
                </div>
            }

            <span asp-validation-for="SelectedRoles" class="text-danger"></span>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            Створити користувача
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Скасувати
        </a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}