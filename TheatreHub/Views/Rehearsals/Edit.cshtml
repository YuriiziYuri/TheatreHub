@model TheatreHub.ViewModels.RehearsalFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using TheatreHub.Models.Enums

@{
    ViewData["Title"] = "Редагування репетиції";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 mb-1">Редагування репетиції</h1>

                <p class="text-muted mb-4">
                    Змініть дані та збережіть результат.
                </p>

                <form asp-action="Edit"
                      asp-route-id="@Model.Id"
                      method="post">

                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="PerformanceId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="PerformanceId"
                                asp-items="@(new SelectList(
                                    Model.Performances,
                                    "Id",
                                    "Title",
                                    Model.PerformanceId))"
                                class="form-select">

                            <option value="0">
                                Оберіть виставу
                            </option>
                        </select>

                        <span asp-validation-for="PerformanceId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDateTime"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="StartDateTime"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="StartDateTime"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDateTime"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="EndDateTime"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="EndDateTime"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HallId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="HallId"
                                asp-items="@(new SelectList(
                                                Model.Halls,
                                                "Id",
                                                "DisplayName",
                                                Model.HallId))"
                                class="form-select">

                            <option value="0">
                                Оберіть зал
                            </option>
                        </select>

                        <span asp-validation-for="HallId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="Status"
                                asp-items="Html.GetEnumSelectList<RehearsalStatus>()"
                                class="form-select">
                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes"
                               class="form-label fw-semibold">
                        </label>

                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="3"></textarea>

                        <span asp-validation-for="Notes"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Учасники репетиції
                        </label>

                        <span asp-validation-for="Actors"
                              class="text-danger d-block mb-2">
                        </span>

                        <div class="border rounded p-3">
                            @for (var i = 0; i < Model.Actors.Count; i++)
                            {
                                <input type="hidden"
                                       asp-for="Actors[i].ActorId" />

                                <input type="hidden"
                                       asp-for="Actors[i].FullName" />

                                <div class="form-check mb-2">
                                    <input asp-for="Actors[i].IsSelected"
                                           class="form-check-input" />

                                    <label class="form-check-label"
                                           asp-for="Actors[i].IsSelected">
                                        @Model.Actors[i].FullName
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit"
                                class="btn btn-primary px-4">
                            Зберегти
                        </button>

                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary">
                            Переглянути
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-dark">
                            До списку
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}