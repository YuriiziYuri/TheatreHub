@model IEnumerable<TheatreHub.Models.Rehearsal>

@{
    ViewData["Title"] = "Репетиції";
}

<div class="d-flex flex-wrap
            justify-content-between
            align-items-center
            gap-3
            mb-4">

    <div>
        <h1 class="h2 mb-1">
            Репетиції
        </h1>

        <p class="text-muted mb-0">
            Планування та контроль театральних репетицій.
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary">
        Створити репетицію
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Репетицій поки немає.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Вистава</th>
                        <th>Початок</th>
                        <th>Завершення</th>
                        <th>Зал</th>
                        <th>Учасники</th>
                        <th>Статус</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a asp-controller="Performances"
                                   asp-action="Details"
                                   asp-route-id="@item.PerformanceId"
                                   class="text-decoration-none">

                                    @item.Performance.Title

                                </a>
                            </td>

                            <td class="text-nowrap">
                                @item.StartDateTime.ToString("dd.MM.yyyy HH:mm")
                            </td>

                            <td class="text-nowrap">
                                @item.EndDateTime.ToString("dd.MM.yyyy HH:mm")
                            </td>

                            <td>
                                <div class="fw-semibold">
                                    @item.Hall.Name
                                </div>

                                <div class="small text-muted">
                                    @item.Hall.Venue.Name
                                </div>
                            </td>

                            <td>
                                @item.Participants.Count
                            </td>

                            <td>
                                @Html.DisplayFor(
                                modelItem => item.Status)
                    </td>

                    <td class="text-end text-nowrap">

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-primary">
                            Деталі
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-secondary">
                            Змінити
                        </a>

                        <a asp-action="Attendance"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-success">
                            Відвідування
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger">
                            Видалити
                        </a>

                    </td>
                </tr>
                                }
                </tbody>

            </table>

        </div>
    </div>
}