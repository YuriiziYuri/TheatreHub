@model TheatreHub.ViewModels.RehearsalFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using TheatreHub.Models.Enums

@{
    ViewData["Title"] = "Створення репетиції";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 mb-1">Створення репетиції</h1>

                <p class="text-muted mb-4">
                    Вкажіть виставу, об’єкт репетиції, час, зал та учасників.
                </p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="PerformanceId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="PerformanceId"
                                asp-items="@(new SelectList(
                                    Model.Performances,
                                    "Id",
                                    "Title",
                                    Model.PerformanceId))"
                                class="form-select">

                            <option value="0">
                                Оберіть виставу
                            </option>
                        </select>

                        <span asp-validation-for="PerformanceId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ActId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="ActId"
                                class="form-select">

                            <option value="">
                                Уся вистава / не обрано
                            </option>

                            @foreach (var act in Model.Acts)
                            {
                                <option value="@act.Id"
                                        selected="@(Model.ActId == act.Id)">
                                    @act.Performance.Title — @act.DisplayName
                                </option>
                            }

                        </select>

                        <span asp-validation-for="ActId"
                              class="text-danger">
                        </span>

                        <div class="form-text">
                            Оберіть дію, якщо репетиція стосується конкретної частини вистави.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SceneId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="SceneId"
                                class="form-select">

                            <option value="">
                                Уся дія / не обрано
                            </option>

                            @foreach (var scene in Model.Scenes)
                            {
                                <option value="@scene.Id"
                                        selected="@(Model.SceneId == scene.Id)">
                                    @scene.Act.Performance.Title —
                                    @scene.Act.DisplayName —
                                    Сцена @scene.Number. @scene.Title
                                </option>
                            }

                        </select>

                        <span asp-validation-for="SceneId"
                              class="text-danger">
                        </span>

                        <div class="form-text">
                            Якщо вибрати сцену, дія буде визначена автоматично.
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDateTime"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="StartDateTime"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="StartDateTime"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDateTime"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="EndDateTime"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="EndDateTime"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HallId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="HallId"
                                asp-items="@(new SelectList(
                                                                    Model.Halls,
                                                                    "Id",
                                                                    "DisplayName",
                                                                    Model.HallId))"
                                class="form-select">

                            <option value="0">
                                Оберіть зал
                            </option>
                        </select>

                        <span asp-validation-for="HallId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="Status"
                                asp-items="Html.GetEnumSelectList<RehearsalStatus>()"
                                class="form-select">
                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes"
                               class="form-label fw-semibold">
                        </label>

                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Додаткові примітки"></textarea>

                        <span asp-validation-for="Notes"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Учасники репетиції
                        </label>

                        <span asp-validation-for="Actors"
                              class="text-danger d-block mb-2">
                        </span>

                        @if (Model.Actors.Count == 0)
                        {
                            <div class="alert alert-warning">
                                У системі ще немає акторів.
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-3">

                                @for (var i = 0; i < Model.Actors.Count; i++)
                                {
                                    <input type="hidden"
                                           asp-for="Actors[i].ActorId" />

                                    <input type="hidden"
                                           asp-for="Actors[i].FullName" />

                                    <div class="form-check mb-2">
                                        <input asp-for="Actors[i].IsSelected"
                                               class="form-check-input" />

                                        <label class="form-check-label"
                                               asp-for="Actors[i].IsSelected">
                                            @Model.Actors[i].FullName
                                        </label>
                                    </div>
                                }

                            </div>
                        }
                    </div>

                    <div class="d-flex flex-wrap gap-2">

                        <button type="submit"
                                name="submitAction"
                                value="fillActors"
                                class="btn btn-outline-success">
                            Підставити акторів за сценою
                        </button>

                        <button type="submit"
                                class="btn btn-primary px-4">
                            Створити
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            До списку
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}