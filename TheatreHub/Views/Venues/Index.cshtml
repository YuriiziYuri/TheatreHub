@model IEnumerable<TheatreHub.Models.Venue>

@{
    ViewData["Title"] = "Майданчики";
}

<div class="d-flex flex-wrap
            justify-content-between
            align-items-center
            gap-3
            mb-4">

    <div>
        <h1 class="h2 mb-1">Майданчики</h1>

        <p class="text-muted mb-0">
            Театри, культурні центри та інші місця проведення.
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary">
        Додати майданчик
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Майданчиків поки немає.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Назва</th>
                        <th>Місто</th>
                        <th>Адреса</th>
                        <th>Контактна особа</th>
                        <th>Зали</th>
                        <th>Статус</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @item.Name
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.City)
                                                        ? "—"
                                                        : item.City)
                                                                </td>

                            <td>
                                @item.Address
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.ContactPerson)
                                                        ? "—"
                                                        : item.ContactPerson)
                    </td>

                            <td>
                                @item.Halls.Count
                            </td>

                            <td>
                        @if (item.IsActive)
                                {
                                    <span class="badge text-bg-success">
                                        Активний
                                    </span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">
                                        Неактивний
                                    </span>
                                }
                            </td>

                            <td class="text-end text-nowrap">
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Деталі
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    Змінити
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Видалити
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
}