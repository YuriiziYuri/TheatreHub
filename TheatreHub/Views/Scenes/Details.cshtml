@model TheatreHub.Models.PerformanceShow

@using TheatreHub.Models.Enums
@using Microsoft.AspNetCore.Authorization
@using TheatreHub.Constants

@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Деталі показу";

    var canManagePerformances =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManagePerformances)).Succeeded;

    var canViewFinance =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanViewFinance)).Succeeded;

    var canManageFinance =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManageFinance)).Succeeded;

    decimal plannedIncomeTotal = ViewBag.PlannedIncomeTotal ?? 0m;
    decimal plannedExpenseTotal = ViewBag.PlannedExpenseTotal ?? 0m;
    decimal plannedProfit = ViewBag.PlannedProfit ?? 0m;

    decimal actualIncomeTotal = ViewBag.ActualIncomeTotal ?? 0m;
    decimal actualExpenseTotal = ViewBag.ActualExpenseTotal ?? 0m;
    decimal actualProfit = ViewBag.ActualProfit ?? 0m;

    int budgetTransactionsCount = ViewBag.BudgetTransactionsCount ?? 0;
}

@functions {
    private static string FormatMoney(decimal amount, string currency = "UAH")
    {
        return $"{amount:N2} {currency}";
    }

    private static string GetTypeText(PerformanceShowType type)
    {
        return type switch
        {
            PerformanceShowType.Premiere => "Прем’єра",
            PerformanceShowType.Regular => "Звичайний показ",
            PerformanceShowType.Touring => "Виїзний показ",
            PerformanceShowType.Closed => "Закритий показ",
            PerformanceShowType.Charity => "Благодійний показ",
            PerformanceShowType.Other => "Інше",
            _ => type.ToString()
        };
    }

    private static string GetStatusText(PerformanceShowStatus status)
    {
        return status switch
        {
            PerformanceShowStatus.Planned => "Заплановано",
            PerformanceShowStatus.Confirmed => "Підтверджено",
            PerformanceShowStatus.Completed => "Проведено",
            PerformanceShowStatus.Cancelled => "Скасовано",
            PerformanceShowStatus.Postponed => "Перенесено",
            _ => status.ToString()
        };
    }

    private static string GetStatusClass(PerformanceShowStatus status)
    {
        return status switch
        {
            PerformanceShowStatus.Planned => "text-bg-secondary",
            PerformanceShowStatus.Confirmed => "text-bg-primary",
            PerformanceShowStatus.Completed => "text-bg-success",
            PerformanceShowStatus.Cancelled => "text-bg-dark",
            PerformanceShowStatus.Postponed => "text-bg-warning text-dark",
            _ => "text-bg-secondary"
        };
    }
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">
            Деталі показу
        </h1>

        <p class="text-muted mb-0">
            @Model.Performance.Title
        </p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        @if (canManageFinance)
        {
            <a asp-controller="BudgetTransactions"
               asp-action="Create"
               asp-route-performanceId="@Model.PerformanceId"
               asp-route-performanceShowId="@Model.Id"
               asp-route-type="Income"
               class="btn btn-outline-success">
                Додати дохід
            </a>

            <a asp-controller="BudgetTransactions"
               asp-action="Create"
               asp-route-performanceId="@Model.PerformanceId"
               asp-route-performanceShowId="@Model.Id"
               asp-route-type="Expense"
               class="btn btn-outline-danger">
                Додати витрату
            </a>
        }

        @if (canManagePerformances)
        {
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Редагувати
            </a>
        }

        <a asp-controller="Performances"
           asp-action="Details"
           asp-route-id="@Model.PerformanceId"
           class="btn btn-outline-secondary">
            До вистави
        </a>

        <a asp-action="Index"
           class="btn btn-outline-dark">
            До списку
        </a>
    </div>
</div>

<div class="row g-4">

    <div class="col-lg-8">

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h2 class="h5 mb-0">
                    Основна інформація
                </h2>

                <span class="badge @GetStatusClass(Model.Status)">
                    @GetStatusText(Model.Status)
                </span>
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Вистава</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Performances"
                           asp-action="Details"
                           asp-route-id="@Model.PerformanceId">
                            @Model.Performance.Title
                        </a>
                    </dd>

                    <dt class="col-sm-4">Тип показу</dt>
                    <dd class="col-sm-8">@GetTypeText(Model.Type)</dd>

                    <dt class="col-sm-4">Статус</dt>
                    <dd class="col-sm-8">@GetStatusText(Model.Status)</dd>

                    <dt class="col-sm-4">Початок</dt>
                    <dd class="col-sm-8">@Model.StartDateTime.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Завершення</dt>
                    <dd class="col-sm-8">@Model.EndDateTime.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Локація</dt>
                    <dd class="col-sm-8">
                        @if (Model.Hall != null)
                        {
                            <span>
                                @(Model.Hall.Venue == null
                                                            ? Model.Hall.Name
                                                            : $"{Model.Hall.Venue.Name} — {Model.Hall.Name}")
                        </span>
                                                }
                        else
                        {
                            <span>
                                @(string.IsNullOrWhiteSpace(Model.ExternalLocation)
                                                            ? "Не вказано"
                                                            : Model.ExternalLocation)
                        </span>
                                                }
                    </dd>

                    <dt class="col-sm-4">Очікувана кількість глядачів</dt>
                    <dd class="col-sm-8">@(Model.ExpectedAudienceCount?.ToString() ?? "Не вказано")</dd>

                    <dt class="col-sm-4">Фактична кількість глядачів</dt>
                    <dd class="col-sm-8">@(Model.ActualAudienceCount?.ToString() ?? "Не вказано")</dd>

                    <dt class="col-sm-4">Примітки</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Notes)
                                                ? "Примітки не вказано"
                                                : Model.Notes)
                    </dd>
                </dl>
            </div>
        </div>

        @if (canViewFinance)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <h2 class="h5 mb-0">
                        Фінанси показу
                    </h2>

                    <div class="d-flex flex-wrap gap-2">
                        @if (canManageFinance)
                        {
                            <a asp-controller="BudgetTransactions"
                               asp-action="Create"
                               asp-route-performanceId="@Model.PerformanceId"
                               asp-route-performanceShowId="@Model.Id"
                               asp-route-type="Income"
                               class="btn btn-sm btn-outline-success">
                                Додати дохід
                            </a>

                            <a asp-controller="BudgetTransactions"
                               asp-action="Create"
                               asp-route-performanceId="@Model.PerformanceId"
                               asp-route-performanceShowId="@Model.Id"
                               asp-route-type="Expense"
                               class="btn btn-sm btn-outline-danger">
                                Додати витрату
                            </a>
                        }

                        <a asp-controller="BudgetTransactions"
                           asp-action="Index"
                           asp-route-performanceId="@Model.PerformanceId"
                           asp-route-performanceShowId="@Model.Id"
                           class="btn btn-sm btn-outline-secondary">
                            Операції цього показу
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <div class="row g-3 mb-3">

                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">Планові доходи</div>
                                <div class="h5 mb-0 text-success">
                                    @FormatMoney(plannedIncomeTotal)
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">Планові витрати</div>
                                <div class="h5 mb-0 text-danger">
                                    @FormatMoney(plannedExpenseTotal)
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">Плановий прибуток</div>
                                <div class="h5 mb-0 @(plannedProfit >= 0 ? "text-success" : "text-danger")">
                                    @FormatMoney(plannedProfit)
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">Фактичні доходи</div>
                                <div class="h5 mb-0 text-success">
                                    @FormatMoney(actualIncomeTotal)
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">Фактичні витрати</div>
                                <div class="h5 mb-0 text-danger">
                                    @FormatMoney(actualExpenseTotal)
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">Фактичний прибуток</div>
                                <div class="h5 mb-0 @(actualProfit >= 0 ? "text-success" : "text-danger")">
                                    @FormatMoney(actualProfit)
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="small text-muted mt-3">
                        Фінансових операцій для цього показу:
                        <strong>@budgetTransactionsCount</strong>
                    </div>
                </div>
            </div>
        }

    </div>

    <div class="col-lg-4">

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">
                    Швидкі дії
                </h2>
            </div>

            <div class="card-body d-grid gap-2">
                @if (canManageFinance)
                {
                    <a asp-controller="BudgetTransactions"
                       asp-action="Create"
                       asp-route-performanceId="@Model.PerformanceId"
                       asp-route-performanceShowId="@Model.Id"
                       asp-route-type="Income"
                       class="btn btn-outline-success">
                        Додати дохід показу
                    </a>

                    <a asp-controller="BudgetTransactions"
                       asp-action="Create"
                       asp-route-performanceId="@Model.PerformanceId"
                       asp-route-performanceShowId="@Model.Id"
                       asp-route-type="Expense"
                       class="btn btn-outline-danger">
                        Додати витрату показу
                    </a>
                }

                @if (canViewFinance)
                {
                    <a asp-controller="BudgetTransactions"
                       asp-action="Index"
                       asp-route-performanceId="@Model.PerformanceId"
                       asp-route-performanceShowId="@Model.Id"
                       class="btn btn-outline-secondary">
                        Фінанси цього показу
                    </a>

                    <a asp-controller="Performances"
                       asp-action="Budget"
                       asp-route-id="@Model.PerformanceId"
                       class="btn btn-outline-primary">
                        Бюджет вистави
                    </a>

                    <a asp-controller="BudgetTransactions"
                       asp-action="Index"
                       asp-route-performanceId="@Model.PerformanceId"
                       class="btn btn-outline-secondary">
                        Фінанси всієї вистави
                    </a>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">
                    Підказка
                </h2>
            </div>

            <div class="card-body">
                <p class="text-muted mb-0">
                    Доходи краще прив’язувати до конкретного показу. Витрати можна прив’язувати або до всієї вистави, або до конкретного показу, якщо вони стосуються саме цієї дати.
                </p>
            </div>
        </div>

    </div>

</div>
