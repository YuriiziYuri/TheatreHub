@model IEnumerable<TheatreHub.Models.Act>

@{
    ViewData["Title"] = "Структура вистави";
    var performanceId =
        (int)ViewBag.PerformanceId;
}

<div class="d-flex flex-wrap
            justify-content-between
            align-items-center
            gap-3
            mb-4">

    <div>
        <h1 class="h2 mb-1">
            Структура вистави
        </h1>

        <p class="text-muted mb-0">
            <strong>
                @ViewBag.PerformanceTitle
            </strong>
        </p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Create"
           asp-route-performanceId="@performanceId"
           class="btn btn-primary">
            Додати дію
        </a>

        <a asp-controller="Performances"
           asp-action="Details"
           asp-route-id="@performanceId"
           class="btn btn-outline-secondary">
            До вистави
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        У виставі ще немає дій.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var act in Model)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">

                        <div class="d-flex flex-wrap
                                            justify-content-between
                                            align-items-start
                                            gap-3">

                            <div>
                                <h2 class="h4 mb-1">
                                    @act.DisplayName
                                </h2>

                                <div class="text-muted">
                                    Сцен: @act.Scenes.Count
                                    · Позиція: @act.Position
                                </div>
                            </div>

                            <div class="d-flex
                                                flex-wrap
                                                gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@act.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Відкрити
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@act.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    Редагувати
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@act.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Видалити
                                </a>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(
                                        act.Description))
                        {
                            <p class="mt-3 mb-0">
                                @act.Description
                            </p>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
}