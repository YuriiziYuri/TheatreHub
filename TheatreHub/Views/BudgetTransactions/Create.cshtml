@model TheatreHub.ViewModels.BudgetTransactionFormViewModel

@{
    ViewData["Title"] = "Додати фінансову операцію";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">
            Додати фінансову операцію
        </h1>

        <p class="text-muted mb-0">
            Створення доходу або витрати для вистави, показу чи постановочного елемента.
        </p>
    </div>

    <div>
        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Назад до фінансів
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create"
              method="post">

            @Html.AntiForgeryToken()

            <partial name="_BudgetTransactionForm"
                     model="Model" />

            <div class="d-flex flex-wrap justify-content-end gap-2 mt-4">
                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Скасувати
                </a>

                <button type="submit"
                        class="btn btn-primary">
                    Зберегти операцію
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}