@model TheatreHub.ViewModels.BudgetTransactionFormViewModel

@{
    ViewData["Title"] = "Редагувати фінансову операцію";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">
            Редагувати фінансову операцію
        </h1>

        <p class="text-muted mb-0">
            Оновлення даних доходу або витрати.
        </p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Details"
           asp-route-id="@Model.Transaction.Id"
           class="btn btn-outline-secondary">
            До деталей
        </a>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Назад до фінансів
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Edit"
              asp-route-id="@Model.Transaction.Id"
              method="post">

            @Html.AntiForgeryToken()

            <partial name="_BudgetTransactionForm"
                     model="Model" />

            <div class="d-flex flex-wrap justify-content-end gap-2 mt-4">
                <a asp-action="Details"
                   asp-route-id="@Model.Transaction.Id"
                   class="btn btn-outline-secondary">
                    Скасувати
                </a>

                <button type="submit"
                        class="btn btn-primary">
                    Зберегти зміни
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}