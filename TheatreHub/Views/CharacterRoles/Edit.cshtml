@model TheatreHub.Models.CharacterRole

@{
    ViewData["Title"] = "Редагування персонажа";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h3 mb-1">
                        Редагування персонажа
                    </h1>

                    <p class="text-muted mb-0">
                        Змініть основну інформацію про персонажа.
                    </p>
                </div>

                <form asp-action="Edit"
                      asp-route-id="@Model.Id"
                      method="post">

                    <input type="hidden"
                           asp-for="Id" />

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"
                         role="alert">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name"
                               class="form-label fw-semibold">
                        </label>

                        <input asp-for="Name"
                               class="form-control" />

                        <span asp-validation-for="Name"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description"
                               class="form-label fw-semibold">
                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PerformanceId"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="PerformanceId"
                                asp-items="ViewBag.PerformanceId"
                                class="form-select">

                            <option value="">
                                Оберіть виставу
                            </option>

                        </select>

                        <span asp-validation-for="PerformanceId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsMainRole"
                               class="form-check-input" />

                        <label asp-for="IsMainRole"
                               class="form-check-label fw-semibold">
                        </label>

                        <div class="form-text">
                            Позначте, якщо персонаж належить до головних ролей вистави.
                        </div>
                    </div>

                    <div class="alert alert-info">
                        Основний і запасний акторські склади редагуються окремо.
                        Зміна даних у цій формі не змінює виконавців ролі.
                    </div>

                    <div class="d-flex flex-wrap gap-2">

                        <button type="submit"
                                class="btn btn-primary px-4">
                            Зберегти
                        </button>

                        <a asp-controller="RoleAssignments"
                           asp-action="Index"
                           asp-route-characterRoleId="@Model.Id"
                           class="btn btn-outline-success">
                            Керувати акторським складом
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary">
                            Переглянути
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-dark">
                            До списку
                        </a>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}