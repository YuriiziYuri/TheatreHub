@model TheatreHub.Models.CharacterRole

@{
    ViewData["Title"] = "Редагування персонажа";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 mb-1">Редагування персонажа</h1>

                <p class="text-muted mb-4">
                    Змініть дані персонажа або призначеного актора.
                </p>

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Name"
                               class="form-control" />

                        <span asp-validation-for="Name"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description"
                               class="form-label fw-semibold"></label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PerformanceId"
                               class="form-label fw-semibold"></label>

                        <select asp-for="PerformanceId"
                                asp-items="ViewBag.PerformanceId"
                                class="form-select">
                            <option value="">Оберіть виставу</option>
                        </select>

                        <span asp-validation-for="PerformanceId"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ActorId"
                               class="form-label fw-semibold"></label>

                        <select asp-for="ActorId"
                                asp-items="ViewBag.ActorId"
                                class="form-select">
                            <option value="">Не призначено</option>
                        </select>

                        <span asp-validation-for="ActorId"
                              class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsMainRole"
                               class="form-check-input" />

                        <label asp-for="IsMainRole"
                               class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            Зберегти
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            До списку
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}