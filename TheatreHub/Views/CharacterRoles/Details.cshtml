@model TheatreHub.Models.CharacterRole
@using TheatreHub.Models.Enums

@{
    ViewData["Title"] = "Деталі персонажа";

    var mainAssignments = Model.Assignments
        .Where(assignment =>
            assignment.CastType == CastType.Main)
        .OrderByDescending(assignment =>
            assignment.IsCurrent)
        .ThenByDescending(assignment =>
            assignment.StartDate)
        .ToList();

    var reserveAssignments = Model.Assignments
        .Where(assignment =>
            assignment.CastType == CastType.Reserve)
        .OrderByDescending(assignment =>
            assignment.IsCurrent)
        .ThenByDescending(assignment =>
            assignment.StartDate)
        .ToList();
}

<div class="row justify-content-center">
    <div class="col-lg-9">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div class="d-flex flex-wrap
                            justify-content-between
                            align-items-start
                            gap-3
                            mb-4">

                    <div>
                        <h1 class="h3 mb-1">
                            @Model.Name
                        </h1>

                        <p class="text-muted mb-0">
                            @Model.Performance.Title
                        </p>
                    </div>

                    @if (Model.IsMainRole)
                    {
                        <span class="badge text-bg-primary">
                            Головна роль
                        </span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">
                            Другорядна роль
                        </span>
                    }

                </div>

                <dl class="row mb-4">

                    <dt class="col-sm-4">
                        Вистава
                    </dt>

                    <dd class="col-sm-8">
                        <a asp-controller="Performances"
                           asp-action="Details"
                           asp-route-id="@Model.PerformanceId"
                           class="text-decoration-none">

                            @Model.Performance.Title

                        </a>
                    </dd>

                    <dt class="col-sm-4">
                        Опис
                    </dt>

                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Description)
                                                ? "Опис відсутній"
                                                : Model.Description)
                    </dd>

                </dl>

                <hr />

                <div class="row g-4">

                    <div class="col-md-6">

                        <h2 class="h5 mb-3">
                            Основний склад
                        </h2>

                        @if (!mainAssignments.Any())
                        {
                            <div class="alert alert-warning">
                                Основного виконавця не призначено.
                            </div>
                        }
                        else
                        {
                            <div class="list-group">

                                @foreach (var assignment
                                                            in mainAssignments)
                                {
                                    <div class="list-group-item">

                                        <div class="d-flex
                                                            justify-content-between
                                                            align-items-start
                                                            gap-2">

                                            <div>
                                                <div class="fw-semibold">
                                                    @assignment.Actor.FullName
                                                </div>

                                                <div class="small text-muted">
                                                    Від
                                                    @assignment.StartDate
                                                    .ToString("dd.MM.yyyy")

                                                    @if (assignment.EndDate.HasValue)
                                                    {
                                                        <span>
                                                            до
                                                            @assignment.EndDate.Value
                                                            .ToString("dd.MM.yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            — дотепер
                                                        </span>
                                                    }
                                                </div>

                                                <div class="small mt-1">
                                                    @Html.DisplayFor(
                                                    modelItem =>
                                                    assignment.Status)
                                        </div>
                                    </div>

                                    @if (assignment.IsCurrent)
                                            {
                                                <span class="badge
                                                                         text-bg-success">
                                                    Поточний
                                                </span>
                                            }

                                        </div>

                                    </div>
                                }

                            </div>
                        }

                    </div>

                    <div class="col-md-6">

                        <h2 class="h5 mb-3">
                            Запасний склад
                        </h2>

                        @if (!reserveAssignments.Any())
                        {
                            <div class="alert alert-light border">
                                Запасного виконавця не призначено.
                            </div>
                        }
                        else
                        {
                            <div class="list-group">

                                @foreach (var assignment
                                                            in reserveAssignments)
                                {
                                    <div class="list-group-item">

                                        <div class="d-flex
                                                            justify-content-between
                                                            align-items-start
                                                            gap-2">

                                            <div>
                                                <div class="fw-semibold">
                                                    @assignment.Actor.FullName
                                                </div>

                                                <div class="small text-muted">
                                                    Від
                                                    @assignment.StartDate
                                                    .ToString("dd.MM.yyyy")

                                                    @if (assignment.EndDate.HasValue)
                                                    {
                                                        <span>
                                                            до
                                                            @assignment.EndDate.Value
                                                            .ToString("dd.MM.yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            — дотепер
                                                        </span>
                                                    }
                                                </div>

                                                <div class="small mt-1">
                                                    @Html.DisplayFor(
                                                    modelItem =>
                                                    assignment.Status)
                                        </div>
                                    </div>

                                    @if (assignment.IsCurrent)
                                            {
                                                <span class="badge
                                                                         text-bg-success">
                                                    Поточний
                                                </span>
                                            }

                                        </div>

                                    </div>
                                }

                            </div>
                        }

                    </div>

                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">

                    <a asp-controller="RoleAssignments"
                       asp-action="Index"
                       asp-route-characterRoleId="@Model.Id"
                       class="btn btn-primary">

                        Керувати акторським складом

                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">

                        Редагувати персонажа

                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-dark">

                        До списку

                    </a>

                </div>

            </div>
        </div>

    </div>
</div>