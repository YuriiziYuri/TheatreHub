@model IEnumerable<TheatreHub.Models.RoleAssignment>

@using Microsoft.AspNetCore.Authorization
@using TheatreHub.Constants

@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Акторські склади";
    var roleId = ViewBag.CharacterRoleId;
    var roleName = ViewBag.CharacterRoleName as string;

    var canManagePerformances =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManagePerformances)).Succeeded;
}

<div class="d-flex flex-wrap
            justify-content-between
            align-items-center
            gap-3
            mb-4">

    <div>
        <h1 class="h2 mb-1">
            Акторські склади
        </h1>

        @if (!string.IsNullOrWhiteSpace(roleName))
        {
            <p class="text-muted mb-0">
                @roleName
            </p>
        }
        else
        {
            <p class="text-muted mb-0">
                Поточні та попередні виконавці театральних ролей
            </p>
        }
    </div>

    @if (canManagePerformances)
    {
        <a asp-action="Create"
           asp-route-characterRoleId="@roleId"
           class="btn btn-primary">
            Додати призначення
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Призначень поки немає.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Вистава</th>
                        <th>Роль</th>
                        <th>Актор</th>
                        <th>Склад</th>
                        <th>Період</th>
                        <th>Статус</th>
                        <th>Поточний</th>
                        <th>Публічний</th>

                        @if (canManagePerformances)
                        {
                            <th class="text-end">Дії</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @item.CharacterRole.Performance.Title
                            </td>

                            <td class="fw-semibold">
                                @item.CharacterRole.Name
                            </td>

                            <td>
                                @item.Actor.FullName
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.CastType)
                            </td>

                            <td class="text-nowrap">
                                @item.StartDate.ToString("dd.MM.yyyy")

                                @if (item.EndDate.HasValue)
                                {
                                    <span>
                                        — @item.EndDate.Value.ToString("dd.MM.yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span>— дотепер</span>
                                }
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.Status)
                            </td>

                            <td>
                                @if (item.IsCurrent)
                                {
                                    <span class="badge text-bg-success">
                                        Так
                                    </span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">
                                        Ні
                                    </span>
                                }
                            </td>

                            <td>
                                @if (item.IsPublic)
                                {
                                    <span class="badge text-bg-primary">
                                        Так
                                    </span>
                                }
                                else
                                {
                                    <span class="badge text-bg-light border">
                                        Ні
                                    </span>
                                }
                            </td>

                            @if (canManagePerformances)
                            {
                                <td class="text-end text-nowrap">

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        Редагувати
                                    </a>

                                    <form asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Видалити це призначення?');">

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            Видалити
                                        </button>

                                    </form>

                                </td>
                            }
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="CharacterRoles"
       asp-action="Index"
       class="btn btn-outline-dark">
        До списку персонажів
    </a>
</div>
