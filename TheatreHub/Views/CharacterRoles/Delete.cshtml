@model TheatreHub.Models.CharacterRole

@{
    ViewData["Title"] = "Видалення персонажа";

    var currentAssignments = Model.Assignments
        .Where(assignment => assignment.IsCurrent)
        .OrderBy(assignment => assignment.CastType)
        .ThenBy(assignment => assignment.Actor.LastName)
        .ThenBy(assignment => assignment.Actor.FirstName)
        .ToList();
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-danger shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 text-danger mb-3">
                    Видалення персонажа
                </h1>

                <div class="alert alert-warning">
                    Після видалення персонажа також будуть видалені всі
                    пов’язані з ним призначення акторів.
                </div>

                <p>
                    Ви дійсно хочете видалити персонажа
                    <strong>«@Model.Name»</strong>?
                </p>

                <dl class="row">

                    <dt class="col-sm-4">
                        Вистава
                    </dt>

                    <dd class="col-sm-8">
                        @Model.Performance?.Title
                    </dd>

                    <dt class="col-sm-4">
                        Персонаж
                    </dt>

                    <dd class="col-sm-8">
                        @Model.Name
                    </dd>

                    <dt class="col-sm-4">
                        Опис
                    </dt>

                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Description)
                                                ? "Опис відсутній"
                                                : Model.Description)
                    </dd>

                    <dt class="col-sm-4">
                        Тип ролі
                    </dt>

                    <dd class="col-sm-8">
                        @(Model.IsMainRole
                                                ? "Головна"
                                                : "Другорядна")
                    </dd>

                    <dt class="col-sm-4">
                        Поточний акторський склад
                    </dt>

                    <dd class="col-sm-8">

                        @if (!currentAssignments.Any())
                        {
                            <span class="text-muted">
                                Акторів не призначено
                            </span>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">

                                @foreach (var assignment in currentAssignments)
                                {
                                    <li class="mb-2">

                                        <span class="fw-semibold">
                                            @assignment.Actor.FullName
                                        </span>

                                        <span class="text-muted">
                                            —
                                            @Html.DisplayFor(
                                            modelItem =>
                                            assignment.CastType)
                                </span>

                            </li>
                                                        }

                            </ul>
                        }

                    </dd>

                </dl>

                <form asp-action="Delete" method="post">

                    <input type="hidden"
                           asp-for="Id" />

                    <div class="d-flex flex-wrap gap-2">

                        <button type="submit"
                                class="btn btn-danger">
                            Видалити
                        </button>

                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary">
                            Переглянути
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-dark">
                            Скасувати
                        </a>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>