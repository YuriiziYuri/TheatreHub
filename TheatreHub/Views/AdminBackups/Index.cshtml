@{
    ViewData["Title"] = "Резервні копії";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Резервні копії</h1>
        <p class="text-muted mb-0">
            Створення резервної копії бази даних TheatreHub.
        </p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="h5">Резервна копія бази даних</h2>

        <p class="text-muted">
            Натисніть кнопку нижче, щоб завантажити архів із поточною копією SQLite-бази даних.
        </p>

        <a asp-controller="AdminBackups"
           asp-action="DownloadDatabaseBackup"
           class="btn btn-success">
            Створити резервну копію
        </a>
    </div>
</div>