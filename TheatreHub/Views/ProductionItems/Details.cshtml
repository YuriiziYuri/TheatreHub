@model TheatreHub.Models.ProductionItem
@using TheatreHub.Models.Enums
@using Microsoft.AspNetCore.Authorization
@using TheatreHub.Constants

@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Деталі постановочного елемента";

    decimal plannedExpenseTotal = ViewBag.PlannedExpenseTotal ?? 0m;
    decimal actualExpenseTotal = ViewBag.ActualExpenseTotal ?? 0m;
    int budgetTransactionsCount = ViewBag.BudgetTransactionsCount ?? 0;

    var canManageProduction =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManageProduction)).Succeeded;

    var canViewFinance =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanViewFinance)).Succeeded;

    var canManageFinance =
        (await AuthorizationService.AuthorizeAsync(
            User,
            AppPolicies.CanManageFinance)).Succeeded;
}

@functions {
    private static string GetTypeText(ProductionItemType type)
    {
        return type switch
        {
            ProductionItemType.Prop => "Реквізит",
            ProductionItemType.Costume => "Костюм",
            ProductionItemType.Makeup => "Грим",
            ProductionItemType.Decoration => "Декорація",
            ProductionItemType.Equipment => "Обладнання",
            ProductionItemType.Other => "Інше",
            _ => type.ToString()
        };
    }

    private static string GetStatusText(ProductionItemStatus status)
    {
        return status switch
        {
            ProductionItemStatus.Needed => "Потрібно",
            ProductionItemStatus.InProgress => "У роботі",
            ProductionItemStatus.Ready => "Готово",
            ProductionItemStatus.Missing => "Проблема",
            ProductionItemStatus.Cancelled => "Скасовано",
            _ => status.ToString()
        };
    }

    private static string GetStatusClass(ProductionItemStatus status)
    {
        return status switch
        {
            ProductionItemStatus.Needed => "text-bg-secondary",
            ProductionItemStatus.InProgress => "text-bg-primary",
            ProductionItemStatus.Ready => "text-bg-success",
            ProductionItemStatus.Missing => "text-bg-danger",
            ProductionItemStatus.Cancelled => "text-bg-dark",
            _ => "text-bg-secondary"
        };
    }

    private static string FormatMoney(decimal amount, string currency = "UAH")
    {
        return $"{amount:N2} {currency}";
    }
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                    <div>
                        <h1 class="h3 mb-1">
                            @Model.Name
                        </h1>

                        <p class="text-muted mb-0">
                            @GetTypeText(Model.Type)
                        </p>
                    </div>

                    <span class="badge @GetStatusClass(Model.Status)">
                        @GetStatusText(Model.Status)
                    </span>
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Вистава</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Performances"
                           asp-action="Details"
                           asp-route-id="@Model.PerformanceId">
                            @Model.Performance.Title
                        </a>
                    </dd>

                    <dt class="col-sm-4">Дія</dt>
                    <dd class="col-sm-8">
                        @if (Model.Act == null)
                        {
                            <span class="text-muted">Не вказано</span>
                        }
                        else
                        {
                            <a asp-controller="Acts"
                               asp-action="Details"
                               asp-route-id="@Model.ActId">
                                @Model.Act.DisplayName
                            </a>
                        }
                    </dd>

                    <dt class="col-sm-4">Сцена</dt>
                    <dd class="col-sm-8">
                        @if (Model.Scene == null)
                        {
                            <span class="text-muted">Не вказано</span>
                        }
                        else
                        {
                            <a asp-controller="Scenes"
                               asp-action="Details"
                               asp-route-id="@Model.SceneId">
                                Сцена @Model.Scene.Number. @Model.Scene.Title
                            </a>
                        }
                    </dd>

                    <dt class="col-sm-4">Кількість</dt>
                    <dd class="col-sm-8">@Model.Quantity</dd>

                    <dt class="col-sm-4">Відповідальний</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.ResponsibleName)
                                                ? "Не вказано"
                                                : Model.ResponsibleName)
                    </dd>

                    <dt class="col-sm-4">Місце зберігання</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.StorageLocation)
                                                ? "Не вказано"
                                                : Model.StorageLocation)
                    </dd>

                    <dt class="col-sm-4">Потрібно до</dt>
                    <dd class="col-sm-8">
                        @(Model.NeededBy.HasValue
                                                ? Model.NeededBy.Value.ToString("dd.MM.yyyy HH:mm")
                                                : "Не вказано")
                    </dd>

                    <dt class="col-sm-4">Створено</dt>
                    <dd class="col-sm-8">
                        @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </dd>

                    <dt class="col-sm-4">Опис</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Description)
                                                ? "Опис не вказано"
                                                : Model.Description)
                    </dd>

                    <dt class="col-sm-4">Примітки</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Notes)
                                                ? "Примітки не вказано"
                                                : Model.Notes)
                    </dd>
                </dl>


                @if (canViewFinance)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <h2 class="h5 mb-0">
                                Фінанси елемента
                            </h2>

                            <div class="d-flex flex-wrap gap-2">
                                @if (canManageFinance)
                                {
                                    <a asp-controller="BudgetTransactions"
                                       asp-action="Create"
                                       asp-route-performanceId="@Model.PerformanceId"
                                       asp-route-productionItemId="@Model.Id"
                                       asp-route-type="Expense"
                                       class="btn btn-sm btn-outline-danger">
                                        Додати витрату
                                    </a>
                                }

                                <a asp-controller="BudgetTransactions"
                                   asp-action="Index"
                                   asp-route-performanceId="@Model.PerformanceId"
                                   asp-route-productionItemId="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    Операції елемента
                                </a>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="row g-3">

                                <div class="col-md-4">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted small">
                                            Планові витрати
                                        </div>

                                        <div class="h5 mb-0 text-danger">
                                            @FormatMoney(plannedExpenseTotal)
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted small">
                                            Фактичні витрати
                                        </div>

                                        <div class="h5 mb-0 text-danger">
                                            @FormatMoney(actualExpenseTotal)
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted small">
                                            Кількість операцій
                                        </div>

                                        <div class="h5 mb-0">
                                            @budgetTransactionsCount
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <div class="small text-muted mt-3">
                                Тут враховуються тільки фінансові операції, прив’язані саме до цього постановочного елемента.
                            </div>
                        </div>
                    </div>

                }

                <div class="d-flex flex-wrap gap-2 mt-4">

                    @if (canManageFinance)
                    {
                        <a asp-controller="BudgetTransactions"
                           asp-action="Create"
                           asp-route-performanceId="@Model.PerformanceId"
                           asp-route-productionItemId="@Model.Id"
                           asp-route-type="Expense"
                           class="btn btn-outline-danger">
                            Додати витрату
                        </a>
                    }

                    @if (canViewFinance)
                    {
                        <a asp-controller="BudgetTransactions"
                           asp-action="Index"
                           asp-route-performanceId="@Model.PerformanceId"
                           asp-route-productionItemId="@Model.Id"
                           class="btn btn-outline-secondary">
                            Операції елемента
                        </a>
                    }

                    @if (canManageProduction)
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-primary">
                            Редагувати
                        </a>

                        @if (Model.Status != ProductionItemStatus.InProgress)
                        {
                            <form asp-action="ChangeStatus"
                                  method="post">
                                <input type="hidden"
                                       name="id"
                                       value="@Model.Id" />

                                <input type="hidden"
                                       name="status"
                                       value="@ProductionItemStatus.InProgress" />

                                <input type="hidden"
                                       name="returnUrl"
                                       value="@Context.Request.Path@Context.Request.QueryString" />

                                <button type="submit"
                                        class="btn btn-outline-primary">
                                    У роботу
                                </button>
                            </form>
                        }

                        @if (Model.Status != ProductionItemStatus.Ready)
                        {
                            <form asp-action="ChangeStatus"
                                  method="post">
                                <input type="hidden"
                                       name="id"
                                       value="@Model.Id" />

                                <input type="hidden"
                                       name="status"
                                       value="@ProductionItemStatus.Ready" />

                                <input type="hidden"
                                       name="returnUrl"
                                       value="@Context.Request.Path@Context.Request.QueryString" />

                                <button type="submit"
                                        class="btn btn-outline-success">
                                    Готово
                                </button>
                            </form>
                        }

                        <a asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-danger">
                            Видалити
                        </a>
                    }

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        До списку
                    </a>

                </div>

            </div>
        </div>

    </div>
</div>