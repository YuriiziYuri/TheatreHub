@model TheatreHub.Models.ProductionItem

@{
    ViewData["Title"] = "Редагувати постановочний елемент";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h1 class="h3 mb-1">
                    Редагувати елемент
                </h1>

                <p class="text-muted mb-4">
                    Оновлення реквізиту, костюму, гриму, декорації або обладнання.
                </p>

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <!-- Далі встав той самий вміст форми, що і в Create.cshtml,
                         починаючи з поля Name і до кнопок. -->

                    <div class="mb-3">
                        <label asp-for="Name"
                               class="form-label">
                            Назва
                        </label>

                        <input asp-for="Name"
                               class="form-control" />

                        <span asp-validation-for="Name"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description"
                               class="form-label">
                            Опис
                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3">
                        </textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Type"
                                   class="form-label">
                                Тип
                            </label>

                            <select asp-for="Type"
                                    asp-items="ViewBag.TypeOptions"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Status"
                                   class="form-label">
                                Статус
                            </label>

                            <select asp-for="Status"
                                    asp-items="ViewBag.StatusOptions"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Quantity"
                                   class="form-label">
                                Кількість
                            </label>

                            <input asp-for="Quantity"
                                   class="form-control" />

                            <span asp-validation-for="Quantity"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PerformanceId"
                               class="form-label">
                            Вистава
                        </label>

                        <select asp-for="PerformanceId"
                                asp-items="ViewBag.PerformanceOptions"
                                class="form-select">
                        </select>

                        <span asp-validation-for="PerformanceId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ActId"
                               class="form-label">
                            Дія
                        </label>

                        <select asp-for="ActId"
                                asp-items="ViewBag.ActOptions"
                                class="form-select">
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SceneId"
                               class="form-label">
                            Сцена
                        </label>

                        <select asp-for="SceneId"
                                asp-items="ViewBag.SceneOptions"
                                class="form-select">
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ResponsibleName"
                               class="form-label">
                            Відповідальний
                        </label>

                        <input asp-for="ResponsibleName"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="StorageLocation"
                               class="form-label">
                            Місце зберігання
                        </label>

                        <input asp-for="StorageLocation"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="NeededBy"
                               class="form-label">
                            Потрібно до
                        </label>

                        <input asp-for="NeededBy"
                               type="datetime-local"
                               value="@(Model.NeededBy.HasValue? Model.NeededBy.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                               class="form-control" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes"
                               class="form-label">
                            Примітки
                        </label>

                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="3">
                        </textarea>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            Зберегти
                        </button>

                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary">
                            Деталі
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-dark">
                            До списку
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}