@model IEnumerable<TheatreHub.Models.ProductionItem>
@using TheatreHub.Models
@using TheatreHub.Models.Enums

@{
    ViewData["Title"] = "Реквізит і постановочні елементи";

    var performances =
        ViewBag.Performances as List<Performance> ?? [];

    int? selectedPerformanceId =
        ViewBag.PerformanceId as int?;

    ProductionItemType? selectedType =
        ViewBag.Type is ProductionItemType typeValue
            ? typeValue
            : null;

    ProductionItemStatus? selectedStatus =
        ViewBag.Status is ProductionItemStatus statusValue
            ? statusValue
            : null;
}

@functions {
    private static string GetTypeText(ProductionItemType type)
    {
        return type switch
        {
            ProductionItemType.Prop => "Реквізит",
            ProductionItemType.Costume => "Костюм",
            ProductionItemType.Makeup => "Грим",
            ProductionItemType.Decoration => "Декорація",
            ProductionItemType.Equipment => "Обладнання",
            ProductionItemType.Other => "Інше",
            _ => type.ToString()
        };
    }

    private static string GetStatusText(ProductionItemStatus status)
    {
        return status switch
        {
            ProductionItemStatus.Needed => "Потрібно",
            ProductionItemStatus.InProgress => "У роботі",
            ProductionItemStatus.Ready => "Готово",
            ProductionItemStatus.Missing => "Проблема",
            ProductionItemStatus.Cancelled => "Скасовано",
            _ => status.ToString()
        };
    }

    private static string GetStatusClass(ProductionItemStatus status)
    {
        return status switch
        {
            ProductionItemStatus.Needed => "text-bg-secondary",
            ProductionItemStatus.InProgress => "text-bg-primary",
            ProductionItemStatus.Ready => "text-bg-success",
            ProductionItemStatus.Missing => "text-bg-danger",
            ProductionItemStatus.Cancelled => "text-bg-dark",
            _ => "text-bg-secondary"
        };
    }
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">
            Реквізит / костюми / грим
        </h1>

        <p class="text-muted mb-0">
            Універсальний список постановочних елементів
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary">
        Додати елемент
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">

        <form asp-action="Index"
              method="get"
              class="row g-3 align-items-end">

            <div class="col-md-4">
                <label class="form-label">
                    Вистава
                </label>

                <select name="performanceId"
                        class="form-select">

                    <option value="">
                        Усі вистави
                    </option>

                    @foreach (var performance in performances)
                    {
                        <option value="@performance.Id"
                                selected="@(selectedPerformanceId == performance.Id ? "selected" : null)">
                            @performance.Title
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">
                    Тип
                </label>

                <select name="type"
                        class="form-select">

                    <option value="">
                        Усі типи
                    </option>

                    @foreach (var type in Enum.GetValues<ProductionItemType>())
                    {
                        <option value="@type"
                                selected="@(selectedType == type ? "selected" : null)">
                            @GetTypeText(type)
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">
                    Статус
                </label>

                <select name="status"
                        class="form-select">

                    <option value="">
                        Усі статуси
                    </option>

                    @foreach (var status in Enum.GetValues<ProductionItemStatus>())
                    {
                        <option value="@status"
                                selected="@(selectedStatus == status ? "selected" : null)">
                            @GetStatusText(status)
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-2 d-flex flex-wrap gap-2">
                <button type="submit"
                        class="btn btn-primary">
                    Фільтр
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Скинути
                </a>
            </div>

        </form>

    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Постановочних елементів поки немає.
    </div>
}
else
{
    <div class="list-group">

        @foreach (var item in Model)
        {
            var isOverdue =
            item.NeededBy.HasValue &&
            item.NeededBy.Value.Date < DateTime.Today &&
            item.Status != ProductionItemStatus.Ready &&
            item.Status != ProductionItemStatus.Cancelled;

            <div class="list-group-item">

                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">

                    <div>
                        <h2 class="h5 mb-1">
                            @item.Name
                        </h2>

                        <div class="small text-muted">
                            @item.Performance.Title

                            @if (item.Act != null)
                            {
                                <span>
                                    · @item.Act.DisplayName
                                </span>
                            }

                            @if (item.Scene != null)
                            {
                                <span>
                                    · Сцена @item.Scene.Number. @item.Scene.Title
                                </span>
                            }
                    </div>

                    <div class="small text-muted mt-1">
                        Тип: @GetTypeText(item.Type)
                        · Кількість: @item.Quantity
                    </div>

                    <div class="small text-muted">
                        Відповідальний:
                        @(string.IsNullOrWhiteSpace(item.ResponsibleName)
                                            ? "не вказано"
                                            : item.ResponsibleName)
                                                               </div>

                    <div class="small text-muted">
                        Потрібно до:
                        @(item.NeededBy.HasValue
                                            ? item.NeededBy.Value.ToString("dd.MM.yyyy HH:mm")
                                            : "не вказано")

                    @if (isOverdue)
                            {
                                <span class="text-danger">
                                    · прострочено
                                </span>
                            }
                        </div>
                    </div>

                    <div class="text-end">

                        <div class="mb-2">
                            <span class="badge @GetStatusClass(item.Status)">
                                @GetStatusText(item.Status)
                            </span>
                        </div>

                        <div class="d-flex flex-wrap gap-2 justify-content-end">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">
                                Деталі
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary">
                                Редагувати
                            </a>

                            @if (item.Status != ProductionItemStatus.InProgress)
                            {
                                <form asp-action="ChangeStatus"
                                      method="post"
                                      class="d-inline">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.Id" />

                                    <input type="hidden"
                                           name="status"
                                           value="@ProductionItemStatus.InProgress" />

                                    <input type="hidden"
                                           name="returnUrl"
                                           value="@Context.Request.Path@Context.Request.QueryString" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-primary">
                                        У роботу
                                    </button>

                                </form>
                            }

                            @if (item.Status != ProductionItemStatus.Ready)
                            {
                                <form asp-action="ChangeStatus"
                                      method="post"
                                      class="d-inline">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.Id" />

                                    <input type="hidden"
                                           name="status"
                                           value="@ProductionItemStatus.Ready" />

                                    <input type="hidden"
                                           name="returnUrl"
                                           value="@Context.Request.Path@Context.Request.QueryString" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-success">
                                        Готово
                                    </button>

                                </form>
                            }

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">
                                Видалити
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}