@model TheatreHub.ViewModels.ActionLogs.UserActionLogIndexViewModel

@{
    ViewData["Title"] = "Журнал дій користувачів";
}

<div class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Журнал дій користувачів</h1>
            <p class="text-muted mb-0">
                Перегляд важливих дій у системі TheatreHub.
            </p>
        </div>

        <a asp-action="ExportToExcel"
           asp-route-search="@Model.Search"
           asp-route-actionType="@Model.ActionType"
           asp-route-entityType="@Model.EntityType"
           asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
           asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
           class="btn btn-success">
            Експортувати в Excel
        </a>
    </div>

    <form method="get" class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Пошук</label>
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           class="form-control"
                           placeholder="Користувач, опис, об’єкт..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Дія</label>
                    <select name="actionType" class="form-select">
                        <option value="">Усі</option>
                        @foreach (var type in Model.ActionTypes)
                        {
                            <option value="@type" selected="@(Model.ActionType == type)">
                                @type
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Об’єкт</label>
                    <select name="entityType" class="form-select">
                        <option value="">Усі</option>
                        @foreach (var type in Model.EntityTypes)
                        {
                            <option value="@type" selected="@(Model.EntityType == type)">
                                @type
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Від дати</label>
                    <input type="date"
                           name="dateFrom"
                           value="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">До дати</label>
                    <input type="date"
                           name="dateTo"
                           value="@Model.DateTo?.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>

                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">
                        Пошук
                    </button>
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary">
                    Скинути фільтри
                </a>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Останні дії</h2>
            <span class="badge text-bg-secondary">@Model.Logs.Count</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Дата</th>
                        <th>Користувач</th>
                        <th>Дія</th>
                        <th>Об’єкт</th>
                        <th>Назва</th>
                        <th>Опис</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Logs.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Записів не знайдено.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var log in Model.Logs)
                        {
                            <tr>
                                <td class="text-nowrap">
                                    @log.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td>
                                    @log.UserFullName
                                </td>

                                <td>
                                    <span class="badge text-bg-primary">
                                        @log.ActionType
                                    </span>
                                </td>

                                <td>
                                    @log.EntityType
                                </td>

                                <td>
                                    @(log.EntityTitle ?? "—")
                                </td>

                                <td>
                                    @log.Description
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>