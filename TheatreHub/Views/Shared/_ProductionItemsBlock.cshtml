@model TheatreHub.ViewModels.ProductionItemsBlockViewModel
@using TheatreHub.Models.Enums

@functions {
    private static string GetTypeText(ProductionItemType type)
    {
        return type switch
        {
            ProductionItemType.Prop => "Реквізит",
            ProductionItemType.Costume => "Костюм",
            ProductionItemType.Makeup => "Грим",
            ProductionItemType.Decoration => "Декорація",
            ProductionItemType.Equipment => "Обладнання",
            ProductionItemType.Other => "Інше",
            _ => type.ToString()
        };
    }

    private static string GetStatusText(ProductionItemStatus status)
    {
        return status switch
        {
            ProductionItemStatus.Needed => "Потрібно",
            ProductionItemStatus.InProgress => "У роботі",
            ProductionItemStatus.Ready => "Готово",
            ProductionItemStatus.Missing => "Проблема",
            ProductionItemStatus.Cancelled => "Скасовано",
            _ => status.ToString()
        };
    }

    private static string GetStatusClass(ProductionItemStatus status)
    {
        return status switch
        {
            ProductionItemStatus.Needed => "text-bg-secondary",
            ProductionItemStatus.InProgress => "text-bg-primary",
            ProductionItemStatus.Ready => "text-bg-success",
            ProductionItemStatus.Missing => "text-bg-danger",
            ProductionItemStatus.Cancelled => "text-bg-dark",
            _ => "text-bg-secondary"
        };
    }
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">

        <div class="d-flex flex-wrap
                    justify-content-between
                    align-items-center
                    gap-3
                    mb-4">

            <div>
                <h2 class="h4 mb-1">
                    @Model.Title
                </h2>

                <p class="text-muted mb-0">
                    @Model.Description
                </p>
            </div>

            @if (Model.SceneId.HasValue)
            {
                <a asp-controller="ProductionItems"
                   asp-action="Create"
                   asp-route-sceneId="@Model.SceneId"
                   class="btn btn-outline-primary">
                    Додати елемент
                </a>
            }
            else if (Model.ActId.HasValue)
            {
                <a asp-controller="ProductionItems"
                   asp-action="Create"
                   asp-route-actId="@Model.ActId"
                   class="btn btn-outline-primary">
                    Додати елемент
                </a>
            }
            else if (Model.PerformanceId.HasValue)
            {
                <a asp-controller="ProductionItems"
                   asp-action="Create"
                   asp-route-performanceId="@Model.PerformanceId"
                   class="btn btn-outline-primary">
                    Додати елемент
                </a>
            }
            else
            {
                <a asp-controller="ProductionItems"
                   asp-action="Create"
                   class="btn btn-outline-primary">
                    Додати елемент
                </a>
            }

        </div>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-info mb-0">
                Постановочних елементів поки немає.
            </div>
        }
        else
        {
            <div class="list-group">

                @foreach (var item in Model.Items)
                {
                    var isOverdue =
                    item.NeededBy.HasValue &&
                    item.NeededBy.Value.Date < DateTime.Today &&
                    item.Status != ProductionItemStatus.Ready &&
                    item.Status != ProductionItemStatus.Cancelled;

                    <div class="list-group-item">

                        <div class="d-flex flex-wrap
                                            justify-content-between
                                            align-items-start
                                            gap-3">

                            <div>
                                <strong>
                                    @item.Name
                                </strong>

                                <div class="small text-muted">
                                    @GetTypeText(item.Type)
                                    ·
                                    Кількість: @item.Quantity
                                </div>

                                @if (item.Act != null)
                                {
                                    <div class="small text-muted">
                                        @item.Act.DisplayName
                                    </div>
                                }

                                @if (item.Scene != null)
                                {
                                    <div class="small text-muted">
                                        Сцена @item.Scene.Number. @item.Scene.Title
                                    </div>
                                }

                            <div class="small text-muted">
                                Відповідальний:
                                @(string.IsNullOrWhiteSpace(item.ResponsibleName)
                                                            ? "не вказано"
                                                            : item.ResponsibleName)
                                                                               </div>

                            <div class="small text-muted">
                                Потрібно до:
                                @(item.NeededBy.HasValue
                                                            ? item.NeededBy.Value.ToString("dd.MM.yyyy HH:mm")
                                                            : "не вказано")

                            @if (isOverdue)
                                    {
                                        <span class="text-danger">
                                            · прострочено
                                        </span>
                                    }
                                </div>
                            </div>

                            <div class="text-end">

                                <div class="mb-2">
                                    <span class="badge @GetStatusClass(item.Status)">
                                        @GetStatusText(item.Status)
                                    </span>
                                </div>

                                <div class="d-flex flex-wrap gap-2 justify-content-end">

                                    <a asp-controller="ProductionItems"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Деталі
                                    </a>

                                    @if (item.Status != ProductionItemStatus.InProgress)
                                    {
                                        <form asp-controller="ProductionItems"
                                              asp-action="ChangeStatus"
                                              method="post"
                                              class="d-inline">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@item.Id" />

                                            <input type="hidden"
                                                   name="status"
                                                   value="@ProductionItemStatus.InProgress" />

                                            <input type="hidden"
                                                   name="returnUrl"
                                                   value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-primary">
                                                У роботу
                                            </button>

                                        </form>
                                    }

                                    @if (item.Status != ProductionItemStatus.Ready)
                                    {
                                        <form asp-controller="ProductionItems"
                                              asp-action="ChangeStatus"
                                              method="post"
                                              class="d-inline">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@item.Id" />

                                            <input type="hidden"
                                                   name="status"
                                                   value="@ProductionItemStatus.Ready" />

                                            <input type="hidden"
                                                   name="returnUrl"
                                                   value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-success">
                                                Готово
                                            </button>

                                        </form>
                                    }

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>
</div>