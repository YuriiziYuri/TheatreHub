@page
@model LoginModel

@{
    ViewData["Title"] = "Вхід до системи";
    ViewData["HideNavbar"] = true;
}

<div class="row justify-content-center align-items-center py-5">
    <div class="col-md-8 col-lg-6 col-xl-4">
        <div class="card border-0 shadow-sm p-4 p-md-5">
            <div class="text-center mb-4">
                <span class="fs-1" style="filter: drop-shadow(0 2px 5px rgba(140, 98, 77, 0.15));">🎭</span>
                <h1 class="h3 fw-bold mt-3 mb-1">TheatreHub</h1>
                <p class="text-muted small">Введіть свої дані для входу до системи</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger text-center small mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold small text-muted">Email адреса</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-semibold small text-muted">Пароль</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label text-muted small" asp-for="Input.RememberMe">
                            Запам'ятати мене
                        </label>
                    </div>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn btn-primary py-2 fs-6 mb-3">
                    Увійти
                </button>

                <div class="text-center mt-3 pt-2 border-top" style="border-top-color: #ede7df !important;">
                    <div class="d-grid gap-1">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small text-muted hover-link">
                            Забули пароль?
                        </a>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none small text-muted hover-link">
                            Реєстрація нового користувача
                        </a>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none small text-muted hover-link">
                            Надіслати підтвердження поштою
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .hover-link {
        transition: color 0.2s ease;
    }
    .hover-link:hover {
        color: var(--color-mint-hover) !important;
    }
</style>
